{
  "name": "@nubisco/openbridge-sdk",
  "version": "0.1.0",
  "description": "Plugin authoring SDK for OpenBridge — definePlugin() helper with full TypeScript types",
  "author": "José Silva <jose@nubisco.io>",
  "license": "MIT",
  "homepage": "https://github.com/nubisco/openbridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nubisco/openbridge.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/nubisco/openbridge/issues"
  },
  "keywords": [
    "homekit",
    "home-automation",
    "plugin",
    "sdk",
    "typescript",
    "openbridge"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nubisco/openbridge-core": "workspace:*",
    "hap-nodejs": ">=0.12.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
