{
  "name": "@openbridge/daemon",
  "version": "0.1.0",
  "description": "Node.js runtime daemon for OpenBridge — plugin loader, Fastify HTTP API, and HAP bridge",
  "author": "José Silva <jose@nubisco.io>",
  "license": "MIT",
  "homepage": "https://github.com/nubisco/openbridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nubisco/openbridge.git",
    "directory": "apps/daemon"
  },
  "bugs": {
    "url": "https://github.com/nubisco/openbridge/issues"
  },
  "keywords": [
    "homebridge",
    "homekit",
    "home-automation",
    "hap",
    "smart-home",
    "plugin",
    "bridge",
    "typescript",
    "docker",
    "nas",
    "synology"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "openbridge": "./dist/index.js",
    "openbridge-daemon": "./dist/index.js"
  },
  "files": [
    "dist/",
    "scripts/"
  ],
  "publishConfig": {
    "name": "openbridge",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "OPENBRIDGE_DEV=true tsx watch --include $HOME/.openbridge/plugins/openbridge src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/fix-node-pty.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/static": "^7.0.1",
    "@fastify/websocket": "^8.3.0",
    "@openbridge/compatibility-homebridge": "workspace:*",
    "@openbridge/config": "workspace:*",
    "@openbridge/core": "workspace:*",
    "@openbridge/logger": "workspace:*",
    "fastify": "^4.26.0",
    "hap-nodejs": "^0.14.3",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0",
    "systeminformation": "^5.31.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
