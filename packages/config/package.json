{
  "name": "@openbridge/config",
  "version": "0.1.0",
  "description": "Zod-validated JSON configuration loader for OpenBridge",
  "author": "José Silva <jose@nubisco.io>",
  "license": "MIT",
  "homepage": "https://github.com/nubisco/openbridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nubisco/openbridge.git",
    "directory": "packages/config"
  },
  "bugs": {
    "url": "https://github.com/nubisco/openbridge/issues"
  },
  "keywords": [
    "config",
    "configuration",
    "zod",
    "validation",
    "typescript",
    "openbridge"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
